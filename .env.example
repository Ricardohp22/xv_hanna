# Copia a `.env` o `.env.local` para desarrollo. No subas secretos al repositorio.

# --- Producción (build en Render): URL pública del API, sin barra final ---
# VITE_API_BASE_URL=https://xv-hanna-api.onrender.com

# --- Desarrollo local (cuando NO defines VITE_API_BASE_URL) ---
VITE_SERVER_IP=localhost
VITE_SERVER_PORT=3000

# Puerto del dev server de Vite (opcional)
# VITE_CLIENT_PORT=5173
